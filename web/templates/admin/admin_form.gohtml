{{ define "admin_form.gohtml" }}<!doctype html><html><head><script src='https://cdn.tailwindcss.com'></script></head><body class='bg-slate-100 p-6'><form method='post' action='/admin/cards' class='max-w-2xl mx-auto bg-white rounded p-6 shadow space-y-3'>
<input name='accommodation_name' placeholder='Accommodation name' class='w-full border p-2'>
<input name='guest_name' placeholder='Guest name' class='w-full border p-2'>
<input name='subtitle' placeholder='Subtitle' class='w-full border p-2'>
<input type='datetime-local' name='check_in_at' class='w-full border p-2'><input type='datetime-local' name='check_out_at' class='w-full border p-2'><input type='datetime-local' name='valid_from' class='w-full border p-2'><input type='datetime-local' name='valid_until' class='w-full border p-2'><input type='datetime-local' name='delete_after' class='w-full border p-2'>
<input name='address' placeholder='Address' class='w-full border p-2'><input name='maps_url' placeholder='Maps URL' class='w-full border p-2'><input name='entry_type' placeholder='Entry type' class='w-full border p-2'><textarea name='entry_instructions' placeholder='Instructions' class='w-full border p-2'></textarea><input name='keybox_code' placeholder='Keybox code' class='w-full border p-2'><input name='wifi_ssid' placeholder='Wi-Fi SSID' class='w-full border p-2'><input name='wifi_password' placeholder='Wi-Fi password' class='w-full border p-2'><textarea name='house_info' placeholder='House info' class='w-full border p-2'></textarea><input name='contact_name' placeholder='Contact name' class='w-full border p-2'><input name='contact_phone' placeholder='Phone' class='w-full border p-2'><input name='contact_whatsapp' placeholder='WhatsApp' class='w-full border p-2'>
<button class='bg-indigo-600 text-white px-4 py-2 rounded'>Save</button></form></body></html>{{ end }}
