{{ define "admin_dashboard.gohtml" }}<!doctype html><html><head><script src='https://cdn.tailwindcss.com'></script></head><body class='p-6 bg-slate-100'><a href='/admin/cards/new' class='bg-indigo-600 text-white px-4 py-2 rounded'>New card</a><div class='mt-4 space-y-2'>{{ range .Cards }}<div class='bg-white p-4 rounded shadow'><strong>{{ .AccommodationName }}</strong><br><small>{{ $.BaseURL }}/c/{{ .Token }}</small><button data-copy-text='{{ $.BaseURL }}/c/{{ .Token }}' class='ml-2 px-2 py-1 bg-slate-200 rounded'>Copy URL</button><form method='post' action='/admin/cards/{{ .ID }}/toggle' class='inline'><button class='ml-2'>Toggle</button></form><form method='post' action='/admin/cards/{{ .ID }}/delete' class='inline' onsubmit="return confirm('Delete card?')"><button class='ml-2 text-red-600'>Delete</button></form></div>{{ end }}</div><script src='/static/js/app.js'></script></body></html>{{ end }}
